# --------------------- Bot Credentials ----------------------
TOKEN=your-discord-bot-token
CLIENT_ID=your-discord-application-client-id
GUILD_ID=your-discord-server-id

# --------------------- Optional APIs ------------------------
OCR_SPACEKEY=your-ocr-space-api-key

# --------------------- Discord Channels ---------------------
CHANNEL_ID1=your-status-channel-id
CHANNEL_ID2=your-timer-channel-id

# ------------------- Legacy Message Command -----------------
ENABLE_LEGACY_MESSAGE_COMMANDS=false
MESSAGE_COMMAND_CHANNEL_ID=your-legacy-command-channel-id

# --------------------- Google Sheets ------------------------
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id
GOOGLE_SHEET_ID=your-google-sheet-tab-id
GOOGLE_SHEET_CACHE=300000

# --------------------- Notifications ------------------------
WEBHOOK_ID=your-discord-webhook-id
WEBHOOK_TOKEN=your-discord-webhook-token

# --------------------- SQLite / Metrics ---------------------
SQLITE_DB_PATH=./data/metrics.db
CHECKPOINT_INTERVAL_MS=300000
METRICS_RETENTION_DAYS=90
METRICS_FLUSH_INTERVAL_MS=1000
METRICS_FLUSH_BATCH_SIZE=50
METRICS_MAX_QUEUE_LENGTH=5000
METRICS_MAX_RETRIES=3

# --------------------- Debug / Runtime ----------------------
DEBUG=false
# DEPLOY_REASON is injected by CI deploys; leave unset locally.
