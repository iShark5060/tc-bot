{
  "name": "tc-bot",
  "version": "7.7.2",
  "description": "Ark of War Theorycrafter Bot",
  "keywords": [],
  "homepage": "https://github.com/ishark5060/tc-bot#readme",
  "bugs": {
    "url": "https://github.com/ishark5060/tc-bot/issues"
  },
  "license": "GPL-3.0-or-later",
  "author": "Shark5060",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishark5060/tc-bot.git"
  },
  "type": "module",
  "main": "dist/tc-bot.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/tc-bot.js",
    "deploy": "tsx src/deployCommands.ts",
    "lint": "oxlint --node-plugin --promise-plugin --import-plugin --vitest-plugin .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "node run-quality-checks.mjs",
    "typecheck": "tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.59.1",
    "@googleapis/sheets": "^13.0.1",
    "@pm2/io": "^6.1.0",
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.25.1",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "gaxios": "^7.1.4",
      "minimatch@>=9": "^10.2.4",
      "undici": "^7.24.5"
    }
  }
}
